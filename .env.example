# Day 09 Lab — Environment Variables
# Copy file này thành .env và điền API key thật:
#   cp .env.example .env   (Mac/Linux)
#   copy .env.example .env (Windows)
#
# KHÔNG commit file .env lên GitHub!

# ─── LLM Provider (Anthropic Claude — kế thừa từ Day 08) ───
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...your-key-here...
LLM_MODEL=claude-sonnet-4-6

# ─── Embedding (VoyageAI — kế thừa từ Day 08) ───
EMBEDDING_PROVIDER=voyageai
VOYAGE_API_KEY=pa-...your-key-here...
VOYAGE_EMBEDDING_MODEL=voyage-multilingual-2

# ─── ChromaDB (dùng lại index từ Day 08) ───
CHROMA_DB_PATH=./chroma_db
CHROMA_COLLECTION=rag_lab

# ─── Retrieval ───────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=3
# Mode: dense | sparse | hybrid  (mặc định: hybrid)
RETRIEVAL_MODE=hybrid

# Rerank — VoyageAI cross-encoder sau retrieve (mặc định: tắt)
# Bật: RETRIEVAL_USE_RERANK=true  |  Cần VOYAGE_API_KEY + gói rerank-2
RETRIEVAL_USE_RERANK=false
VOYAGE_RERANK_MODEL=rerank-2

# Query Transformation — LLM biến đổi query trước retrieve (mặc định: tắt)
# Bật: RETRIEVAL_USE_TRANSFORM=true  |  Cần ANTHROPIC_API_KEY (gọi thêm 1 LLM call)
RETRIEVAL_USE_TRANSFORM=false
# Strategy: expansion | decomposition | hyde
RETRIEVAL_TRANSFORM_STRATEGY=expansion

# ─── Trace ───
TRACE_OUTPUT_DIR=./artifacts/traces
